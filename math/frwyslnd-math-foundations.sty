% SET-THEORETIC NOTATION
%% Cardinal number.
%%%% Source:
%%%% https://tex.stackexchange.com/a/730865
\ExplSyntaxOn
\DeclarePairedDelimiter{\__card}{\lvert}{\rvert}
\NewDocumentCommand{\card}{s o d<> m}{
  \IfBooleanTF{#1}
  {
    \__card*{\egreg_spacedarg:nn {#3}{\IfBlankTF{#4}{\blank}{#4}}}
  }
  {
    \IfNoValueTF{#2}
    {
      \__card{\egreg_spacedarg:nn {#3}{\IfBlankTF{#4}{\blank}{#4}}}
    }
    {
      \__card[#2]{\egreg_spacedarg:nn {#3}{\IfBlankTF{#4}{\blank}{#4}}}
    }
  }
}
\ExplSyntaxOff
\DeclareMathOperator{\cardop}{card}

