% LOGICAL CONNECTIVES
%% Material conditional (material implication).
%%% Left to right.
\newcommand*{\ifthen}{\DOTSB\rightarrow}
\newcommand*{\materiallyimplies}{\ifthen}
\newcommand*{\onlyif}{\ifthen}
\AtBeginDocument{\renewcommand*{\implies}{\ifthen}}

%%% Right to left.
\newcommand*{\isimpliedby}{\DOTSB\leftarrow}
\newcommand*{\lif}{\isimpliedby}
\newcommand*{\materiallyimpliedby}{\isimpliedby}
\AtBeginDocument{\renewcommand*{\impliedby}{\isimpliedby}}

%% Material biconditional (material bi-implication).
\newcommand*{\ifandonlyif}{\iff}
\AtBeginDocument{\renewcommand*{\iff}{\DOTSB\leftrightarrow}}

%% Negation.
\NewDocumentCommand{\negationof}{s O{3mu} m}{
  \IfBooleanTF{#1}{\overline{#3}}{\trimmedoverline[#2]{#3}}
}

% LOGICAL DEFINITIONS AND EQUALITIES
%% Defined-to-be-equal-to.
\newcommand*{\defeq}{\coloneq}
\newcommand*{\defiff}{\text{ :iff }}

%% If and only if.
\newcommand*{\iffdef}{\text{ iff: }}
\AtBeginDocument{\renewcommand*{\eqdef}{\eqcolon}}

%% Questionable equality.
\newcommand*{\questioneq}{\overset{?}{=}}

% LOGICAL QUANTIFIERS
%% Existential quantifier.
\newcommand*{\forsome}{\exists}
\newcommand*{\thereexists}{\exists}
\newcommand*{\thereissome}{\exists}

%%% Universal quantifier.
\newcommand*{\forevery}{\forall}
\newcommand*{\givenany}{\forall}

% METALOGICAL NOTATION
%% Assertion.
\AtBeginDocument{\renewcommand*{\assert}{\vdash}}

%% End-of-proof symbol (tombstone or halmos or Q.E.D).
\renewcommand*{\qedsymbol}{\(\mdlgblksquare\)}

%% Model.
\AtBeginDocument{\renewcommand*{\models}{\vDash}}

%% Semantic consequence (entailment).
\newcommand*{\entailedby}{\Dashv}
\newcommand*{\entails}{\vDash}
\newcommand*{\isentailedby}{\entailedby}

%% Syntactic consequence (derivability).
\newcommand*{\derivablefrom}{\dashv}
\newcommand*{\isderivablefrom}{\derivablefrom}
\newcommand*{\proves}{\vdash}

