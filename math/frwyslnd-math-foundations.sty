%% Set specification.
%%% Source:
%%% https://tex.stackexchange.com/a/763668
\ExplSyntaxOn
\NewDocumentCommand{\set}{sO{}m}
{
  \group_begin:
  \seq_set_split:Nnn \l__egreg_set_input_seq {\suchthat} {#3}
  \int_case:nnF { \seq_count:N \l__egreg_set_input_seq }
  {
    {1} { \__egreg_set_bylist:nnn {#1} {#2} {#3} }
    {2} {
      \__egreg_set_byproperty:nnee {#1} {#2}
      { \seq_item:Nn \l__egreg_set_input_seq {1} }
      { \seq_item:Nn \l__egreg_set_input_seq {2} }
    }
  }{OOPS!}
  \group_end:
}

\seq_new:N \l__egreg_set_input_seq
\tl_new:N \l__egreg_set_st_tl

\cs_new_protected:Nn \__egreg_set_byproperty:nnnn
{
  \bool_if:nTF {#1}
  {% auto sizing
    \left\lbrace #3 \nonscript\;\middle\vert\nonscript\; #4 \right\rbrace
  }
  {
    \mathopen{#2\lbrace} #3 \mathrel{#2|} #4 \mathclose{#2\rbrace}
  }
}
\cs_generate_variant:Nn \__egreg_set_byproperty:nnnn {nnee}

\cs_new_protected:Nn \__egreg_set_bylist:nnn
{
  \bool_if:nTF {#1} { \left\lbrace } { \mathopen{#2\lbrace} }
  \group_begin:
  \clist_use:nn {#3} {,\penalty0~\hspace{0pt plus 3pt}}
  \group_end:
  \bool_if:nTF {#1} { \right\rbrace } { \mathclose{#2\rbrace} }
}
\ExplSyntaxOff

%% Set union.
\newcommand*{\union}{\cup}

%% Tuple.
%%% Source:
%%% https://tex.stackexchange.com/a/763668
\ExplSyntaxOn
\NewDocumentCommand{\tuple}{sO{}m}
{
  \group_begin:
  \seq_set_split:Nnn \l__egreg_tuple_input_seq {\suchthat} {#3}
  \int_case:nnF { \seq_count:N \l__egreg_tuple_input_seq }
  {
    {1} { \__egreg_tuple_bylist:nnn {#1} {#2} {#3} }
    {2} {
      \__egreg_tuple_byproperty:nnee {#1} {#2}
      { \seq_item:Nn \l__egreg_tuple_input_seq {1} }
      { \seq_item:Nn \l__egreg_tuple_input_seq {2} }
    }
  }{OOPS!}
  \group_end:
}

\seq_new:N \l__egreg_tuple_input_seq
\tl_new:N \l__egreg_tuple_st_tl

\cs_new_protected:Nn \__egreg_tuple_byproperty:nnnn
{
  \bool_if:nTF {#1}
  {% auto sizing
    \left( #3 \nonscript\;\middle\vert\nonscript\; #4 \right)
  }
  {
    \mathopen{#2(} #3 \mathrel{#2|} #4 \mathclose{#2)}
  }
}
\cs_generate_variant:Nn \__egreg_tuple_byproperty:nnnn {nnee}

\cs_new_protected:Nn \__egreg_tuple_bylist:nnn
{
  \bool_if:nTF {#1} { \left( } { \mathopen{#2(} }
      \group_begin:
      \clist_use:nn {#3} {,\penalty0~\hspace{0pt plus 3pt}}
      \group_end:
  \bool_if:nTF {#1} { \right) } { \mathclose{#2)} }
}
