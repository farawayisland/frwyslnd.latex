%%% Induction environment.
%%%% Source:
%%%% https://tex.stackexchange.com/a/762886
\newenvironment{induction}
{\if@inlabel\else\par\vspace{\topsep}\noindent\fi\ignorespaces}
{\par\vspace{\topsep}}
\newcommand*{\bstep}{\ifvmode\noindent\fi(\textit{Base case})\ \ignorespaces}
\newcommand*{\istep}{\par\medskip\noindent(\textit{Induction step})\
\ignorespaces}

%% Theorem environments.
%%% Custom \newcustomtheorem macro.
%%%% Source:
%%%% https://tex.stackexchange.com/a/752203
\AtBeginDocument{
  \NewDocumentCommand{\newcustomtheorem}{m m}{%
    \newtheorem{custom#1inner}{#2}
    \crefformat{custom#1inner}{##2#2~##1##3}
    \NewDocumentEnvironment{custom#1}{m}{%
      \IfBlankTF{##1}{%
        \expandafter\renewcommand\csname thecustom#1inner\endcsname{\unskip}
      }{%
        \expandafter\renewcommand\csname thecustom#1inner\endcsname{##1}
      }%
      \csname custom#1inner\endcsname
    }{%
      \csname endcustom#1inner\endcsname
    }
  }
}

