% COLORED TEXT
%% Custom \customtextcolor macro.
%%% Source:
%%% https://tex.stackexchange.com/a/400677
\NewDocumentCommand{\customtextcolor}{s O{\normalsize} D<>{0.06ex} m m m}{%
  \begin{tikzpicture}[anchor=base,baseline]%
    \node[font=#2] at (0,0) {%
      \IfBooleanTF{#1}{%
        \textpdfrender{
          FillColor=#5,
          LineWidth=#3,
          StrokeColor=#4,
          TextRenderingMode=FillStrokeClip,
        }{#6}%
      }{%
        \textpdfrender{
          FillColor=#5,
          LineWidth=#3,
          MiterLimit=10,
          StrokeColor=#4,
          TextRenderingMode=FillStrokeClip,
        }{#6}%
      }
    };
  \end{tikzpicture}%
}

% COLOR SHOWCASES
%% Custom \ShowcaseColor macro.
\newcommand*{\ShowcaseColor}[1]{%
  \fcolorbox{#1}{#1}{%
    \customtextcolor[\Huge\ttfamily\bfseries]{black}{white}{#1}%
  }%
}

