\NeedsTeXFormat{LaTeX2e}[2026-06-01]
\ProvidesPackage{frwyslnd-reference}[2026/07/06 The `reference` package of the
`frwyslnd` bundle]

% ENGINE
%% The `frwyslnd` bundle strictly requires LuaTeX as the author does not intend
%% to write checks for other TeX engines.

% DEPENDENCIES
%% `frwyslnd-core`: The `core` package of the `frwyslnd` bundle.
\RequirePackage{frwyslnd-core}

%% `hyperref`: Extensive support for hypertext in LaTeX.
%%% Loaded by `bookmark`.
%%% \RequirePackage{hyperref}

%% `bookmark`: A new bookmark (outline) organization for `hyperref`.
%%% Requires `hyperref` but should be loaded after it if you want to explicitly
%%% load `hyperref`.
\RequirePackage{bookmark}

%% `cleveref`: Intelligent cross-referencing.
%%% Should be loaded after `hyperref`.
\RequirePackage[capitalise,nameinlink]{cleveref}

%% `hypcap`: Adjusting the anchors of captions.
%%% Should be loaded after `hyperref`.
\RequirePackage[all]{hypcap}

% CONFIGURATIONS
%% `hyperref`.
%%% Source:
%%% https://tex.stackexchange.com/a/150984
\hypersetup{
  colorlinks=true,
  filecolor=CustomBlue01,
  linkcolor=CustomBlue01,
  linktoc=all,
  pdfpagelayout=SinglePage,
  pdfpagemode=UseOutlines,
  pdfview=Fit,
  urlcolor=CustomBlue01,
}
\renewcommand*{\Hy@numberline}[1]{#1. }

%% `bookmark`.
\bookmarksetup{
  addtohook={%
    \ifnum\bookmarkget{level}<1%
    \bookmarksetup{bold}%
    \fi
  },
  numbered,
  open,
}

\endinput
