package of the `frwyslnd` bundle]

% ENGINE
%% The `frwyslnd` bundle strictly requires LuaTeX as the author does not intend
%% to write checks for other TeX engines.

% DEPENDENCIES
%% `frwyslnd-core-table`: The `table` module of the `core` package of the
%% `frwyslnd` bundle.

%% `calc`: Simple arithmetic in LaTeX commands.
%%% Loaded by `scalerel`.
%%% \RequirePackage{calc}

%% `etoolbox`: e-TeX tools for LaTeX.
%%% Loaded by `scalerel`.
%%% \RequirePackage{etoolbox}

%% `xpatch`: Extending `etoolbox` patching commands.
\RequirePackage{xpatch}

% ALIGNMENT MACROS
%% Custom \mathwithwidth and \textwithwidth macros.
%%% Source:
%%% https://tex.stackexchange.com/a/212719
\NewDocumentCommand{\mathwithwidth}{O{l} m m}{
  \mathmakebox[\widthof{\(#3\)}][#1]{#2}
}
\NewDocumentCommand{\textwithwidth}{O{l} m m}{\makebox[\widthof{#3}][#1]{#2}}

% SEARCH-AND-REPLACE MACROS
%% Custom \replaceany and \replaceword macros.
%%% Source:
%%% https://tex.stackexchange.com/a/213952
\ExplSyntaxOn
\NewDocumentCommand{\replaceall}{mmm}
{
  \marian_replace_all:nnn {#1} {#2} {#3}
}

\tl_new:N \l_marian_input_text_tl_all

\cs_new_protected:Npn \marian_replace_all:nnn #1 #2 #3
{
  \tl_set:Nn \l_marian_input_text_tl_all { #1 }
  \tl_replace_all:Nnn \l_marian_input_text_tl_all { #2 } { #3 }
  \tl_use:N \l_marian_input_text_tl_all
}

\NewDocumentCommand{\replacewordsonly}{mmm}
{
  \marian_replace_words_only:nnn {#1} {#2} {#3}
}

\tl_new:N \l_marian_input_text_tl_words_only
\tl_new:N \l_marian_search_tl_words_only
\tl_new:N \l_marian_replace_tl_words_only

\cs_new_protected:Npn \marian_replace_words_only:nnn #1 #2 #3
{
  \tl_set:Nn \l_marian_input_text_tl_words_only { #1 }
  \tl_set:Nn \l_marian_search_tl_words_only { #2 }
  \tl_set:Nn \l_marian_replace_tl_words_only { #3 }
  \regex_replace_all:nnN { \b\u{l_marian_search_tl_words_only}\b } {
  \u{l_marian_replace_tl_words_only} } \l_marian_input_text_tl_words_only
  \tl_use:N \l_marian_input_text_tl_words_only
}
\ExplSyntaxOff

% STRING-COMPARISON MACROS
%% Custom \IfBlankXF, \IfBlankXTF, \IfBlankXT macros.
%%% Source:
%%% https://tex.stackexchange.com/a/737951
\ExplSyntaxOn
\NewExpandableDocumentCommand{\IfBlankXF}{mm}
{
  \tl_if_blank:eF { \text_expand:n {#1} } {#2}
}
\NewExpandableDocumentCommand{\IfBlankXT}{mm}
{
  \tl_if_blank:eT { \text_expand:n {#1} } {#2}
}
\NewExpandableDocumentCommand{\IfBlankXTF}{mmm}
{
  \tl_if_blank:eTF { \text_expand:n {#1} } {#2} {#3}
}
\ExplSyntaxOff

%% Custom \IfStrEqualTF and \StrCase macros.
%%% Source:
%%% https://tex.stackexchange.com/a/451094
\ExplSyntaxOn
\NewExpandableDocumentCommand{\IfStrEqualTF}{m m m m}
{
  \str_if_eq:eeTF { #1 } { #2 } { #3 } { #4 }
}
\NewExpandableDocumentCommand{\StrCase}{m O{} m}
{
  \str_case_e:nnF { #1 } { #3 } { #2 }
}
\ExplSyntaxOff

% LENGTH-RELATED MACROS
%% Custom \definelength macro.
%%% Source:
%%% https://tex.stackexchange.com/a/172267
\ExplSyntaxOn
\NewDocumentCommand{\definelength}{ s m m }
{
  \IfBooleanTF { #1 }
  { \prefix_definelength:nnn { dim }  { #2 } { #3 } }
  { \prefix_definelength:nnn { skip } { #2 } { #3 } }
}

\cs_new_protected:Npn \prefix_definelength:nnn #1 #2 #3
{
  \cs_if_exist:cTF { #2 }
  {
    \msg_error:nnn { frwyslnd-core } { already~defined } { #2 }
  }
  {
    \__prefix_definelength:nnn { #1 } { #2 } { #3 }
  }
}
\cs_new_protected:Npn \__prefix_definelength:nnn #1 #2 #3
{
  \use:c { #1_new:c } { l_prefix_#2_#1 }
  \use:c { #1_set:cn } { l_prefix_#2_#1 } { #3 }
  \cs_set_eq:cc { #2 } { l_prefix_#2_#1 } % user level name
}

\msg_new:nnnn { frwyslnd-core } { already~defined }
{
  Control~sequence~\exp_not:c { #1 } already~defined.
}
{
  The~control~sequence~\exp_not:c { #1 } already~exists.~
  Please~use~a~new~name;~the~command~will~not~be~executed.
}
\ExplSyntaxOff

\endinput
