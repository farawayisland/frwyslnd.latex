\NeedsTeXFormat{LaTeX2e}[2026-06-01]
\ProvidesPackage{frwyslnd-core-listing}[2026/06/29 The `listing` module of the
`core` package of the `frwyslnd` bundle]

% ENGINE
%% The `frwyslnd` bundle strictly requires LuaTeX as the author does not intend
%% to write checks for other TeX engines.

% DEPENDENCIES
%% `frwyslnd-core-list`: The `list` module of the `core` package of the
%% `frwyslnd` bundle.

%% `minted`: Highlighted source code for LaTeX.
\RequirePackage{minted}

% CONFIGURATIONS
%% `minted`.
%%% C.
\newmintedfile[inputc]{c}{
  autogobble,
  firstnumber=1,
  fontfamily=tt,
  fontsize=\scriptsize,
  frame=single,
  linenos,
  stepnumber=5,
}

%%% Python.
\newmintedfile[inputpython]{python}{
  autogobble,
  firstnumber=1,
  fontfamily=tt,
  fontsize=\scriptsize,
  frame=single,
  linenos,
  stepnumber=5,
}

\endinput
