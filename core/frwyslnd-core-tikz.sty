\NeedsTeXFormat{LaTeX2e}[2026-06-01]
\ProvidesPackage{frwyslnd-core-tikz}[2026/06/29 The `tikz` module of the
`core` package of the `frwyslnd` bundle]

% ENGINE
%% The `frwyslnd` bundle strictly requires LuaTeX as the author does not intend
%% to write checks for other TeX engines.

% DEPENDENCIES
%% `frwyslnd-core-placeholder`: The `placeholder` module of the `core` package
%% of the `frwyslnd` bundle.

%% `tikz`: Create PostScript and PDF graphics in TeX.
%%% Loaded by `tcolorbox`.
%%% \RequirePackage{tikz}

%% `tcolorbox`: Colored boxes, for LaTeX examples and theorems, etc.
\RequirePackage{tcolorbox}

%% `tikz-cd`: Create commutative diagrams with TikZ.
\RequirePackage{tikz-cd}

% TIKZ LIBRARIES
\usetikzlibrary{calligraphy}
\usetikzlibrary{decorations.pathreplacing}
\usetikzlibrary{intersections}

% CONFIGURATIONS
% `tikz-cd`.
\tikzcdset{
  arrow style=tikz,
  diagrams={
    shorten=4pt,
    >={Straight Barb[round,scale=0.675,width=7pt]}
  },
}

\endinput
