\NeedsTeXFormat{LaTeX2e}[2026-06-01]
\ProvidesPackage{frwyslnd-core-list}[2026/06/29 The `list` module of the `core`
package of the `frwyslnd` bundle]

% ENGINE
%% The `frwyslnd` bundle strictly requires LuaTeX as the author does not intend
%% to write checks for other TeX engines.

% DEPENDENCIES
%% `frwyslnd-core-chrono`: The `chrono` module of the `core` package of the
%% `frwyslnd` bundle.

%% `enumitem`: Control layout of itemize, enumerate, description.
\RequirePackage{enumitem}

% CONFIGURATIONS
%% `enumitem` general list environments.
\setlist{
  align=left,
  before=\normalsize\normalfont,
  font=\normalsize\normalfont,
  itemindent=0pt,
  labelsep=3.5pt,
  nosep,
}

\endinput
