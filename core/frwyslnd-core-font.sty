%% Asana Math.
%%% Primary math font, which must be loaded last.
%%% Source:
%%% https://ctan.org/tex-archive/fonts/Asana-Math
\setmathfont[
  Scale=1,
  version=asana-math,
]{Asana Math}
\setmathfont[
  range={bfcal,cal},
  Scale=1,
  Style=Alternate,
]{Asana Math}

%% Asana Math calligraphic R patch.
%%% Source:
%%% https://tex.stackexchange.com/a/538972
\newcommand{\ToggleAsanaMathCalRPatch}{
  \directlua{
    % We want to stop the fontloader from discarding names it considers useless,
    % so enable keepnames.
    fonts.privateoffsets.keepnames = true
    % That's not quite enough because the font is most likely already cached
    % without the names, so disable the cache.
    % WARNING: This affects all fonts you load in this document from here on,
    % which will make your document significantly slower.
    fonts.handlers.otf.cache.enabled = false
    fonts.handlers.otf.addfeature {
      name = "asana-salt-r",
      type = "substitution",
      data = {
        [0x211B] = "uni211B.salt"
      },
    }
  }
  \setmathfont[
    range={bfcal,cal},
    RawFeature=asana-salt-r,
    Scale=1,
    Style=Alternate,
  ]{Asana Math}
}

\endinput
