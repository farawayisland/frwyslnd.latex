% DEPENDENCIES
%% `frwyslnd-core-language`: The `language` module of the `core` package of the
%% `frwyslnd` bundle.

%% `newpx`: Alternative uses of the PX fonts, with improved metrics.
\usepackage[
  largesc,
  no-math,
  otfmath,
  theoremfont,
  trueslanted,
]{newpxtext}

%% `amsmath`: AMS mathematical facilities for LaTeX.
%%% Loaded by `mathtools`.
%% \RequirePackage{amsmath}

%% `mathtools`: Mathematical tools to use with `amsmath`.
\RequirePackage{mathtools}

%% `unicode-math`: Unicode mathematics support for XeTeX and LuaTeX.
%%% Loaded by `newpx` but not loaded by `newpxtext`.
\RequirePackage[
  warnings-off={mathtools-colon,mathtools-overbracket},
]{unicode-math}

