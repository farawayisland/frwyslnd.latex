%%% Patch for \models and \vDash.
%%%% Source:
%%%% https://tex.stackexchange.com/a/764027
\AtBeginDocument{\PatchAsanaMathWrongSymbols}

\ExplSyntaxOn
\NewDocumentCommand{\PatchAsanaMathWrongSymbols}{}
{
  \NewCommandCopy{\standardmodels}{\models}
  \NewCommandCopy{\standardvDash}{\vDash}
  \RenewDocumentCommand{\models}{}
  {
    \str_if_eq:vnTF {math@version} {normal} {\standardvDash} {\standardmodels}
  }
  \RenewDocumentCommand{\vDash}{}
  {
    \str_if_eq:vnTF {math@version} {normal} {\standardmodels} {\standardvDash}
  }
}
\ExplSyntaxOff

