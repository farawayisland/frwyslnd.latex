\NeedsTeXFormat{LaTeX2e}[2026-06-01]
\ProvidesPackage{frwyslnd-core-font}[2026/06/29 The `font` module of the `core`
package of the `frwyslnd` bundle]

% ENGINE
%% The `frwyslnd` bundle strictly requires LuaTeX as the author does not intend
%% to write checks for other TeX engines.

% DEPENDENCIES
%% `frwyslnd-core-language`: The `language` module of the `core` package of the
%% `frwyslnd` bundle.

%% `newpxtext`: Alternative uses of the PX fonts, with improved metrics.
%%% Should be loaded before `unicode-math` in order to pass the `no-math` option
%%% to `fontspec`, which is loaded by `unicode-math`.
\usepackage[
  largesc,
  no-math,
  otfmath,
  theoremfont,
  trueslanted,
]{newpxtext}

%% `amsmath`: AMS mathematical facilities for LaTeX.
%%% Loaded by `mathtools`.
%%% \RequirePackage{amsmath}

%% `mathtools`: Mathematical tools to use with `amsmath`.
%%% Should be loaded before `unicode-math`.
\RequirePackage{mathtools}

%% `unicode-math`: Unicode mathematics support for XeTeX and LuaTeX.
%%% Loaded by `newpx` but not loaded by `newpxtext`.
\RequirePackage[
  warnings-off={mathtools-colon,mathtools-overbracket},
]{unicode-math}

% SERIF TEXT FONTS
%% TeX Gyre PagellaX.
%%% Primary serif text font.
%%%% Loaded by `newpxtext`.
%%%% Source:
%%%% https://ctan.org/tex-archive/fonts/newpx/opentype
%%%% \setmainfont{TeX Gyre PagellaX}[
%%%%   Scale=1,
%%%% ]

%% NewComputerModern10.
%%% Additional serif text font.
%%%% Source:
%%%% https://www.ctan.org/tex-archive/fonts/newcomputermodern/otf
\newfontfamily{\NCM}{NewCM10}[
  BoldFont=*-Bold,
  BoldItalicFont=*-BoldItalic,
  Extension=.otf,
  ItalicFont=*-BookItalic,
  Scale=MatchUppercase,
  UprightFont=*-Book,
]

% SANS TEXT FONTS
%% URW Classico.
%%% Primary sans-serif text font.
%%%% Sources:
%%%% https://ctan.org/tex-archive/fonts/urw/classico/opentype
%%%% https://tug.org/fonts/getnonfreefonts/
\setsansfont{URWClassico}[
  BoldFont=*-Bold,
  BoldItalicFont=*-BoldItalic,
  Extension=.otf,
  ItalicFont=*-Italic,
  Scale=0.94,
  UprightFont=*-Regular,
]

%% NewComputerModernSans10.
%%% Additional sans-serif text font.
%%%% Source:
%%%% https://www.ctan.org/tex-archive/fonts/newcomputermodern/otf
\newfontfamily{\NCMSans}{NewCMSans10}[
  BoldFont=*-Bold,
  BoldItalicFont=*-BoldOblique,
  Extension=.otf,
  ItalicFont=*-BookOblique,
  Scale=MatchUppercase,
  UprightFont=*-Book,
]

%% TeX Gyre Heros.
%%% Additional sans-serif text font.
%%%% Source:
%%%% https://ctan.org/tex-archive/fonts/tex-gyre/opentype
\newfontfamily{\TGHeros}{texgyreheros}[
  BoldFont=*-bold,
  BoldItalicFont=*-bolditalic,
  Extension=.otf,
  ItalicFont=*-italic,
  Scale=0.94,
  UprightFont=*-regular,
]

% MONOSPACED TEXT FONTS
%% Inconsolatazi4.
%%% Primary monospaced text font.
%%%% Source:
%%%% https://ctan.org/tex-archive/fonts/inconsolata/opentype
\setmonofont{Inconsolatazi4}[
  BoldFont=*-Bold,
  Extension=.otf,
  Scale=0.95,
  StylisticSet={1,3},
  UprightFont=*-Regular,
]

%% JetBrains Mono.
%%% Additional monospaced text font.
%%%% Source:
%%%% https://ctan.org/tex-archive/fonts/jetbrainsmono-otf/fonts/opentype/SIL/jetbrainsmono
\newfontfamily{\JBMono}{JetBrainsMono}[
  BoldFont=*-Medium,
  BoldItalicFont=*-MediumItalic,
  Extension=.otf,
  ItalicFont=*-LightItalic,
  Scale=MatchUppercase,
  UprightFont=*-Light,
]

%% NewComputerModernMono10.
%%% Additional monospaced text font.
%%%% Source:
%%%% https://www.ctan.org/tex-archive/fonts/newcomputermodern/otf
\newfontfamily{\NCMMono}{NewCMMono10}[
  BoldFont=*-Bold,
  BoldItalicFont=*-BoldOblique,
  Extension=.otf,
  ItalicFont=*-Italic,
  Scale=MatchUppercase,
  UprightFont=*-Regular,
]

% MATH FONTS
%% Asana Math.
%%% Primary math font which should be set first.
%%%% Source:
%%%% https://ctan.org/tex-archive/fonts/Asana-Math
\setmathfont{Asana Math}[
  Scale=1,
  Style=Alternate,
]
\setmathfont{Asana Math}[
  Scale=1,
  Style=Alternate,
  version=asana-math,
]

%%% Patch for calligraphic R.
%%%% Source:
%%%% https://tex.stackexchange.com/a/538972
\NewDocumentCommand{\PatchAsanaMathCalR}{}{
  \directlua{
    % We want to stop the fontloader from discarding names it considers useless,
    % so enable keepnames.
    fonts.privateoffsets.keepnames = true
    % That's not quite enough because the font is most likely already cached
    % without the names, so disable the cache.
    % WARNING: This affects all fonts you load in this document from here on,
    % which will make your document significantly slower.
    fonts.handlers.otf.cache.enabled = false
    fonts.handlers.otf.addfeature {
      name = "asana-math-salt-r",
      type = "substitution",
      data = {
        [0x211B] = "uni211B.salt"
      },
    }
  }
  \setmathfont{Asana Math}[
    RawFeature=asana-math-salt-r,
    Scale=1,
    Style=Alternate,
    version=asana-math-salt-r,
  ]
  \setmathfont{STIX Two Math}[
    range={
      \acidfree,
